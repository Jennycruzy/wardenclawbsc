# ── App ───────────────────────────────────────────────────────────────────────
DATABASE_URL=
NEXT_PUBLIC_API_URL=
APP_MODE=development

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider selection: explicit LLM_PROVIDER wins; else anthropic if ANTHROPIC_API_KEY,
# else openai if OPENAI_API_KEY, else disabled (deterministic/manual mode).
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
# OpenAI-compatible gateway override. Point the openai provider at any
# OpenAI-compatible endpoint (Alibaba DashScope/Qwen, Together, Groq, ...).
# For Qwen: OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#           OPENAI_API_KEY=<your DashScope/Qwen key>  OPENAI_MODEL=qwen-plus
OPENAI_BASE_URL=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
STRATEGY_COMPILER_MODEL=
NEWS_SENTIMENT_MODEL=
AUDIT_SUMMARY_MODEL=
POST_TRADE_REFLECTION_MODEL=
LLM_TEMPERATURE=0.1
LLM_ENABLED=true

# ── CoinMarketCap Agent Hub ───────────────────────────────────────────────────
CMC_API_KEY=
CMC_MCP_URL=
CMC_X402_ENDPOINT=https://pro-api.coinmarketcap.com
CMC_X402_ENABLED=true
# x402 is paid TWAK-first (`twak x402 request`), settling via the route TWAK picks
# (EIP-3009/Permit2). Pin a chain with X402_PREFER_NETWORK (e.g. bsc or base).
X402_MAX_PAYMENT_ATOMIC=10000      # max auto-approved payment, atomic units (10000 = 0.01 USDC @ 6dp)
X402_ASSET=                        # optional --prefer-asset (name substring or contract address)
X402_PREFER_NETWORK=               # optional: pin x402 settlement chain (bsc | base | ...)
X402_REQUIRED=false                # if true, block a trade when x402 is unavailable/failed
# Fallback ONLY: raw viem CMC x402 client (USDC on Base, EIP-3009). Off by default.
# When on, payments are labeled `viem_fallback (non-TWAK)` — never shown as TWAK x402.
X402_FALLBACK_VIEM=false
X402_PRIVATE_KEY=                  # a Base account with a little USDC (viem fallback only)

# ── Trust Wallet Agent Kit (sole BSC executor) ────────────────────────────────
# Get TWAK_ACCESS_ID / TWAK_HMAC_SECRET from portal.trustwallet.com, then `twak init`.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_CONFIG_PATH=
TWAK_AGENT_WALLET=
TWAK_WALLET_PASSWORD=
TWAK_BIN=twak
TWAK_AUTONOMOUS_MODE=true
TWAK_MAX_DAILY_SPEND_USD=20
TWAK_MAX_TRADE_USD=30
TWAK_MAX_SLIPPAGE_BPS=50
TWAK_X402_ENABLED=true

# ── BNB AI Agent SDK sidecar (Python `bnbagent`, ERC-8004 identity) ───────────
BNB_SDK_REGISTER=false
BNB_SDK_NETWORK=bsc
BNB_AGENT_WALLET_PASSWORD=
BNB_AGENT_PRIVATE_KEY=
BNB_AGENT_NAME=wardenclaw-bsc
BNB_AGENT_ENDPOINT=
PYTHON_BIN=python3

# ── BNB / BSC (spot-only, verified competition) ───────────────────────────────
BSC_RPC_URLS=                       # comma-separated, with failover
BSC_CHAIN_ID=56
REQUIRED_CHAIN_ID=56
EXECUTION_VENUE=bsc
EXECUTION_TYPE=spot_only
ROUTER_ALLOWED=pancakeswap
BNB_AGENT_SDK_ENABLED=true
COMPETITION_CONTRACT_ADDRESS=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
ELIGIBLE_TOKENS_PATH=data/eligible-tokens.json
COMPETITION_RULES_STATUS=verified-with-4-open-items

# ── Capital & sizing ($40 book) ───────────────────────────────────────────────
STARTING_CAPITAL_USD=40
GAS_RESERVE_USD=2                   # native BNB, gas only — not portfolio capital
MAX_CONCURRENT_POSITIONS=1
PER_TRADE_RISK_PCT=3
STOP_ATR_MULTIPLE=1.5               # initial volatility stop distance
BREAKEVEN_TRIGGER_ATR=1.0          # gain (in ATR) that arms the breakeven+fees ratchet
TRAIL_ATR_MULTIPLE=1.5             # trail distance below the high-water mark
TRAIL_TIGHT_ATR_MULTIPLE=1.0       # tighter trail for defend/red states
MAX_POSITION_PCT=70
ATTACK_NOTIONAL_MIN_USD=15
MICRO_SCOUT_USD=5

# Fast position-watch loop (protection cadence, only while a position is open)
POSITION_WATCH_INTERVAL_SECONDS=45
WATCH_STALENESS_LIMIT_SECONDS=180
WATCH_STALENESS_ACTION=alert_only  # alert_only | reduce

# ── Entry quality (catalyst uncrowding + rs_continuation) ─────────────────────
# Catalyst keys on CHANGE not level: rank must climb fast (or freshly enter the
# top-N), volume must expand off its own baseline, and never the first vertical —
# require a post-spike base + continuation. rs_continuation needs two consecutive
# outperformance checks vs the benchmark with rising volume.
TRENDING_DELTA_MIN=5               # rank places of improvement required since last check
TRENDING_TOP_N=30                  # rank ≤ this counts as a fresh top-N entry
VOLUME_EXPANSION_MIN=1.5           # 24h volume ≥ this × the token's recent baseline
SPIKE_COOLDOWN_CHECKS=2            # consolidation checks required before a continuation entry
MAX_RETRACE_PCT=0.5                # max fraction of the spike a base may retrace
SPIKE_MIN_PCT=0.08                 # a run-up ≥ this counts as a "spike" for the no-first-spike guard
RS_OUTPERFORM_MIN_BPS=200          # required outperformance vs benchmark, both checks
MIN_TRADES_PER_DAY=1               # verified official minimum (7/week)
TARGET_TRADES_PER_DAY=2
MAX_TRADES_PER_DAY=3

# ── Week-schedule risk budget (HUNT/PRESS/DEFEND, win-first sizing) ────────────
# Risk is budgeted across the competition WEEK, not just per trade. The state
# machine sets a size multiplier from week-to-date return, give-back drawdown, and
# legs (round-trip entries) remaining. The multiplier scales only the governor's
# allowed size — MAX_POSITION_PCT and the volatility stop still bind, so PRESS can
# never breach the hard caps. Win-first: a lead past LOCK_IN_RETURN_PCT is defended.
WEEKLY_LEG_BUDGET=14               # total round-trip entries budgeted for the week
PRESS_THRESHOLD_PCT=8              # week return ≥ this and budget healthy → PRESS (size up)
DEFEND_THRESHOLD_PCT=-3            # week return ≤ this → DEFEND (size down)
LOCK_IN_RETURN_PCT=25             # week return ≥ this → DEFEND to protect the lead
MAX_GIVE_BACK_PCT=5               # drawdown from the week peak that forces DEFEND
PRESS_SIZE_MULTIPLIER=1.3         # size multiplier while pressing (>1, capped downstream)
DEFEND_SIZE_MULTIPLIER=0.5        # size multiplier while defending (<1)
LATE_WEEK_FRACTION=0.7            # past this fraction of the week, scarce legs force DEFEND

# ── Red-day regime analyst (GREEN/NEUTRAL/RED with hysteresis) ────────────────
# Three deterministic breadth signals are voted each cycle: benchmark 24h change,
# CMC Fear & Greed, and the fraction of majors up. A committed RED regime blocks
# new directional entries (REJECT_REGIME_RED; scout + safety exits exempt) and the
# worker rotates open positions to stables. A regime switch needs
# REGIME_HYSTERESIS_CHECKS consecutive confirming reads (no flip-flop on one cycle).
RED_BENCHMARK_PCT=-4              # benchmark 24h ≤ this votes RED
GREEN_BENCHMARK_PCT=2             # benchmark 24h ≥ this votes GREEN
RED_FEAR_GREED=25                # Fear & Greed ≤ this votes RED
GREEN_FEAR_GREED=60              # Fear & Greed ≥ this votes GREEN
RED_BREADTH=0.3                  # majors-up fraction ≤ this votes RED
GREEN_BREADTH=0.6                # majors-up fraction ≥ this votes GREEN
REGIME_HYSTERESIS_CHECKS=2       # consecutive confirming reads required to switch

# ── Drawdown / survival (three layers) ────────────────────────────────────────
COMPETITION_DQ_DRAWDOWN_PCT=30     # disqualifier; indicative value, confirm with organizer
INTERNAL_WINDOW_DRAWDOWN_PCT=15
MAX_DAILY_DRAWDOWN_PCT=6
SOFT_DRAWDOWN_PCT=4
COMPETITION_FLOOR_USD=1.00         # verified $1 hourly zeroing rule
DANGER_PORTFOLIO_VALUE_USD=8

# ── Micro-capital economics + calibration ─────────────────────────────────────
NET_EDGE_MIN_BPS=30                # tune from calibration
FRICTION_BUDGET_BPS=120
SCORING_SIM_COST_BPS=10            # per trade leg, conservative default (drives the Scored Ledger gate)
WALLET_FLOOR_FRACTION=0.75         # expected move must exceed this × measured real round-trip (Wallet Ledger)
# The real round-trip cost is MEASURED from fills (entry notional vs actual exit
# proceeds, isolated from the price move) and rolled into the Wallet Ledger; it
# drives the wallet floor and the dust gate. A directional entry whose measured
# real round-trip exceeds the ceiling is dust (fixed gas swamps a tiny notional).
DUST_ROUND_TRIP_CEILING_BPS=350    # measured real round-trip above this = REJECT_DUST_TRADE
MAX_SLIPPAGE_BPS=50
SHADOW_FILL_TOLERANCE_BPS=40
KELLY_FRACTION=0.25
CALIBRATION_MAX_AGE_DAYS=7
HOURLY_SNAPSHOT_ENABLED=true

# ── Ops ───────────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
KILL_SWITCH_TOKEN=
HEARTBEAT_INTERVAL_SECONDS=60
DAILY_TRADE_RISK_ALERT_HOURS=4
API_PORT=4000
WORKER_INTERVAL_SECONDS=300
WORKER_MAX_CYCLES=0
# Set after `twak compete register` so /bsc/proof shows the registration tx:
REGISTRATION_TX_HASH=
# Explicit override to start live mode before all manual rehearsal steps are confirmed:
REHEARSAL_OVERRIDE=false

# ── Approval safety ───────────────────────────────────────────────────────────
ALLOW_INFINITE_APPROVALS=false
APPROVAL_BUFFER_BPS=50
REVOKE_APPROVALS_ON_STOP=true
ALLOWED_SPENDERS_PATH=
ALLOWED_CONTRACTS_PATH=
