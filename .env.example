# ── App ───────────────────────────────────────────────────────────────────────
DATABASE_URL=
NEXT_PUBLIC_API_URL=
APP_MODE=development

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider selection: explicit LLM_PROVIDER wins; else anthropic if ANTHROPIC_API_KEY,
# else openai if OPENAI_API_KEY, else disabled (deterministic/manual mode).
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
# OpenAI-compatible gateway override. Point the openai provider at any
# OpenAI-compatible endpoint (Alibaba DashScope/Qwen, Together, Groq, ...).
# For Qwen: OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#           OPENAI_API_KEY=<your DashScope/Qwen key>  OPENAI_MODEL=qwen-plus
OPENAI_BASE_URL=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
STRATEGY_COMPILER_MODEL=
NEWS_SENTIMENT_MODEL=
AUDIT_SUMMARY_MODEL=
POST_TRADE_REFLECTION_MODEL=
LLM_TEMPERATURE=0.1
LLM_ENABLED=true

# ── CoinMarketCap Agent Hub ───────────────────────────────────────────────────
CMC_API_KEY=
CMC_MCP_URL=
CMC_X402_ENDPOINT=https://pro-api.coinmarketcap.com
CMC_X402_ENABLED=true
# x402 settles in USDC on Base (EIP-3009). A Base account with a little USDC:
X402_PRIVATE_KEY=

# ── Trust Wallet Agent Kit (sole BSC executor) ────────────────────────────────
# Get TWAK_ACCESS_ID / TWAK_HMAC_SECRET from portal.trustwallet.com, then `twak init`.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_CONFIG_PATH=
TWAK_AGENT_WALLET=
TWAK_WALLET_PASSWORD=
TWAK_BIN=twak
TWAK_AUTONOMOUS_MODE=true
TWAK_MAX_DAILY_SPEND_USD=20
TWAK_MAX_TRADE_USD=30
TWAK_MAX_SLIPPAGE_BPS=50
TWAK_X402_ENABLED=true

# ── BNB AI Agent SDK sidecar (Python `bnbagent`, ERC-8004 identity) ───────────
BNB_SDK_REGISTER=false
BNB_SDK_NETWORK=bsc
BNB_AGENT_WALLET_PASSWORD=
BNB_AGENT_PRIVATE_KEY=
BNB_AGENT_NAME=wardenclaw-bsc
BNB_AGENT_ENDPOINT=
PYTHON_BIN=python3

# ── BNB / BSC (spot-only, verified competition) ───────────────────────────────
BSC_RPC_URLS=                       # comma-separated, with failover
BSC_CHAIN_ID=56
REQUIRED_CHAIN_ID=56
EXECUTION_VENUE=bsc
EXECUTION_TYPE=spot_only
ROUTER_ALLOWED=pancakeswap
BNB_AGENT_SDK_ENABLED=true
COMPETITION_CONTRACT_ADDRESS=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
ELIGIBLE_TOKENS_PATH=data/eligible-tokens.json
COMPETITION_RULES_STATUS=verified-with-4-open-items

# ── Capital & sizing ($40 book) ───────────────────────────────────────────────
STARTING_CAPITAL_USD=40
GAS_RESERVE_USD=2                   # native BNB, gas only — not portfolio capital
MAX_CONCURRENT_POSITIONS=1
PER_TRADE_RISK_PCT=3
STOP_ATR_MULTIPLE=1.5
MAX_POSITION_PCT=70
ATTACK_NOTIONAL_MIN_USD=15
MICRO_SCOUT_USD=5
MIN_TRADES_PER_DAY=1               # verified official minimum (7/week)
TARGET_TRADES_PER_DAY=2
MAX_TRADES_PER_DAY=3

# ── Drawdown / survival (three layers) ────────────────────────────────────────
COMPETITION_DQ_DRAWDOWN_PCT=30     # disqualifier; indicative value, confirm with organizer
INTERNAL_WINDOW_DRAWDOWN_PCT=15
MAX_DAILY_DRAWDOWN_PCT=6
SOFT_DRAWDOWN_PCT=4
COMPETITION_FLOOR_USD=1.00         # verified $1 hourly zeroing rule
DANGER_PORTFOLIO_VALUE_USD=8

# ── Micro-capital economics + calibration ─────────────────────────────────────
NET_EDGE_MIN_BPS=30                # tune from calibration
FRICTION_BUDGET_BPS=120
SCORING_SIM_COST_BPS=10            # per trade leg, conservative default
MAX_SLIPPAGE_BPS=50
SHADOW_FILL_TOLERANCE_BPS=40
KELLY_FRACTION=0.25
CALIBRATION_MAX_AGE_DAYS=7
HOURLY_SNAPSHOT_ENABLED=true

# ── Ops ───────────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
KILL_SWITCH_TOKEN=
HEARTBEAT_INTERVAL_SECONDS=60
DAILY_TRADE_RISK_ALERT_HOURS=4
API_PORT=4000
WORKER_INTERVAL_SECONDS=300
WORKER_MAX_CYCLES=0
# Set after `twak compete register` so /bsc/proof shows the registration tx:
REGISTRATION_TX_HASH=
# Explicit override to start live mode before all manual rehearsal steps are confirmed:
REHEARSAL_OVERRIDE=false

# ── Approval safety ───────────────────────────────────────────────────────────
ALLOW_INFINITE_APPROVALS=false
APPROVAL_BUFFER_BPS=50
REVOKE_APPROVALS_ON_STOP=true
ALLOWED_SPENDERS_PATH=
ALLOWED_CONTRACTS_PATH=
