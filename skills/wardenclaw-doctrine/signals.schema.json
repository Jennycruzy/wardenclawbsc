{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jennycruzy/wardenclawbsc/skills/wardenclaw-doctrine/signals.schema.json",
  "title": "WARDENCLAW Doctrine Signal",
  "description": "One signal/state object the wardenclaw-doctrine Skill emits per decision cycle. The Skill is spec-only: it emits signals and strategy state, never orders. Streams are newline-delimited JSON (JSONL), one object per line.",
  "type": "object",
  "required": ["schema_version", "ts", "mode", "kind"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "ts": { "type": "string", "description": "ISO-8601 timestamp of the decision cycle" },
    "mode": {
      "type": "string",
      "enum": ["backtest", "paper", "live"],
      "description": "Provenance of the signal. Backtest signals are labeled 'backtest'."
    },
    "data_source": {
      "type": "string",
      "description": "Optional label of the input data (e.g. 'cmc-history', 'documented-synthetic-fixture')."
    },
    "kind": {
      "type": "string",
      "enum": ["regime_state", "week_state", "entry_candidate", "sizing", "exit_instruction"]
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/regime_state" },
    { "$ref": "#/$defs/week_state" },
    { "$ref": "#/$defs/entry_candidate" },
    { "$ref": "#/$defs/sizing" },
    { "$ref": "#/$defs/exit_instruction" }
  ],
  "$defs": {
    "reasons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Human-readable deterministic reasons that produced this signal."
    },
    "net_edge": {
      "type": "object",
      "required": ["expected_move_bps", "scored_friction_bps", "required_move_bps", "margin_bps", "passed"],
      "additionalProperties": false,
      "properties": {
        "expected_move_bps": { "type": "number" },
        "scored_friction_bps": { "type": "number", "minimum": 0 },
        "required_move_bps": { "type": "number" },
        "margin_bps": { "type": "number" },
        "passed": { "type": "boolean" }
      }
    },
    "regime_state": {
      "type": "object",
      "required": ["kind", "state", "raw_regime", "score", "blocks_entries", "reasons"],
      "properties": {
        "kind": { "const": "regime_state" },
        "state": { "type": "string", "enum": ["GREEN", "NEUTRAL", "RED"] },
        "raw_regime": { "type": "string", "enum": ["GREEN", "NEUTRAL", "RED"] },
        "score": { "type": "integer", "minimum": -5, "maximum": 5, "description": "Net regime vote: trend +/-2, sentiment +/-1, breadth +/-1, volatility +/-1." },
        "pending_count": { "type": "integer", "minimum": 0 },
        "blocks_entries": { "type": "boolean" },
        "reasons": { "$ref": "#/$defs/reasons" }
      }
    },
    "week_state": {
      "type": "object",
      "required": ["kind", "state", "minimum_score", "size_multiplier", "tight_trail", "press_trade", "reasons"],
      "properties": {
        "kind": { "const": "week_state" },
        "state": { "type": "string", "enum": ["HUNT", "PRESS", "DEFEND"] },
        "minimum_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "size_multiplier": { "type": "number", "minimum": 0 },
        "net_edge_bonus_bps": { "type": "number", "minimum": 0 },
        "tight_trail": { "type": "boolean" },
        "press_trade": { "type": "boolean" },
        "legs_remaining": { "type": "number", "minimum": 0 },
        "reasons": { "$ref": "#/$defs/reasons" }
      }
    },
    "entry_candidate": {
      "type": "object",
      "required": ["kind", "symbol", "family", "score", "expected_move_bps", "passed", "regime_gated_ok", "net_edge", "reasons"],
      "properties": {
        "kind": { "const": "entry_candidate" },
        "symbol": { "type": "string" },
        "family": { "type": "string", "enum": ["catalyst", "rs_continuation", "momentum"] },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "expected_move_bps": { "type": "number" },
        "passed": { "type": "boolean", "description": "True only when every gate for this family cleared." },
        "regime_gated_ok": { "type": "boolean", "description": "Whether the current regime permits this family (RED blocks directional entries)." },
        "reject_code": {
          "type": ["string", "null"],
          "description": "Deterministic reject code when passed=false (e.g. REJECT_TRENDING_STALE), else null."
        },
        "net_edge": { "$ref": "#/$defs/net_edge" },
        "reasons": { "$ref": "#/$defs/reasons" }
      }
    },
    "sizing": {
      "type": "object",
      "required": ["kind", "symbol", "size_fraction", "binding_layer", "stop_distance_pct", "reasons"],
      "properties": {
        "kind": { "const": "sizing" },
        "symbol": { "type": "string" },
        "size_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "binding_layer": { "type": "string", "enum": ["competition", "window", "daily"] },
        "kelly_fraction": { "type": "number", "minimum": 0 },
        "edge_estimate": { "type": "number", "minimum": 0, "maximum": 1 },
        "remaining_budget_pct": { "type": "number" },
        "stop_distance_pct": { "type": "number", "minimum": 0 },
        "position_notional_usd": { "type": "number", "minimum": 0 },
        "reasons": { "$ref": "#/$defs/reasons" }
      }
    },
    "exit_instruction": {
      "type": "object",
      "required": ["kind", "symbol", "action", "reasons"],
      "properties": {
        "kind": { "const": "exit_instruction" },
        "symbol": { "type": "string" },
        "action": { "type": "string", "enum": ["HOLD", "EXIT"] },
        "exit_reason": {
          "type": ["string", "null"],
          "enum": ["EXIT_STOP", "EXIT_TRAIL_RATCHET", "EXIT_REGIME_RED", "EXIT_PORTFOLIO_DANGER", null]
        },
        "stop_price": { "type": "number", "minimum": 0 },
        "high_water_mark": { "type": "number", "minimum": 0 },
        "breakeven_armed": { "type": "boolean" },
        "tight_mode": { "type": "boolean" },
        "reasons": { "$ref": "#/$defs/reasons" }
      }
    }
  }
}
